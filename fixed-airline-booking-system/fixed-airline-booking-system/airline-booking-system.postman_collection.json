		{
			"name": "Eureka Server",
			"item": [
				{
					"name": "Eureka Dashboard Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is HTML dashboard\", function () {",
									"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/html\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{eureka_url}}",
							"host": [
								"{{eureka_url}}"
							]
						},
						"description": "Checks the status of the Eureka Service Registry dashboard at port 8761."
					},
					"response": []
				}
			],
			"description": "Requests relating to Eureka Server registry dashboard."
		},
		{
