									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an(\"object\");",
									"    pm.expect(jsonData.flightNumber).to.eql(\"AI303\");",
									"    pm.expect(jsonData.origin).to.eql(\"Chennai\");",
									"    pm.expect(jsonData.destination).to.eql(\"Kolkata\");",
									"});"
								],
								"type": "text/javascript"
							}
