									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is an array of flights\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an(\"array\");",
									"    pm.expect(jsonData).to.include(\"AI101 - Pune to Delhi\");",
									"    pm.expect(jsonData).to.include(\"AI202 - Mumbai to Bangalore\");",
									"});"
								],
